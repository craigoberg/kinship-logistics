# Yada Connect — copy to .env and fill in values from Supabase Dashboard.
# Project Settings → API: publishable key + service_role secret (different keys).

# Client (safe to expose in browser bundle)
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Server handlers (createServerFn, internal routes)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Server-only — Admin restore truncate. NEVER prefix with VITE_.
# NEVER commit the real value. Store in host secrets for production.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...
